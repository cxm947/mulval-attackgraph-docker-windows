	attackVectorInjection(H, _, Protocol, Port)),
  rule_desc('DDOS-Application or System Exploitation - T1499.004', 1.0)
).

/****** Defense Evasion ******/
interaction_rule(
  (execCode(HostD, Perm) :-
	execCode(HostS, Perm),
	ttpExists(HostD, _, Software, remoteClient, networkBoundaryBridging, defenseEvasion),
	networkServiceInfo(HostD, Software, Protocol, Port, Perm),
	hacl(HostS, HostD, Protocol, Port)),
  rule_desc('Network Boundary Bridging Network Address Translation Traversal - T1599.001', 1.0)
).

interaction_rule(
  (execCode(HostD, Perm) :-
	hacl(HostS, HostD, Protocol, Port),
	ttpExists(HostD, Software, remoteClient, disguisedLegitimateDocument, defenseEvasion),
	networkServiceInfo(HostD, Software, Protocol, Port, Perm),
	netAccess(HostD, Protocol, Port)),
  rule_desc('Masquerading - Match Legitimate Name or Location - T1036.005', 1.0)
).

interaction_rule(
  (disableFirewall(HostD) :-
	isFirewall(HostD, exit),
	execCode(HostS, system),
	ttpExists(HostD, Software, remoteClient, remoteDisableDefenses, defenseEvasion),
	networkServiceInfo(HostD, Software, Protocol, Port, Perm),
	hacl(HostS, HostD, Protocol, Port)),
  rule_desc('Impair Defenses - Disable or Modify Tools - T1562.001', 1.0)
).

