primitive(inCompetent(_user, _host, _perm)).
primitive(hacl(_src, _dst, _prot, _port)).
primitive(attackerLocated(_host)).
primitive(networkServiceInfo(_host, _program, _protocol, _port, _user)).
primitive(ttpExists(_machine,_vulID,_program,_range, _tech, _tactics)).
primitive(ttpExists(_machine,_program,_range, _tech, _tactics)).
primitive(nfsMount(_dst, _dstpath, _software, _perm, _sec)).
primitive(leakAccount(_user, _host, _perm)).
primitive(hasAccount(_host, _user, _passwd, _perm)).
primitive(pathExists(_host, _path, _writable, _perm)).
primitive(isDocker(_host, _docker)).
primitive(weakAccount(_host, _user, _passwd, _perm)).
primitive(isFirewall(_host, _state)).

derived(execCode(_host, _user)).
derived(netAccess(_machine,_protocol,_port)).
derived(attackVectorInjection(_host, _user, _protocol, _port)).
derived(getAccount(_host, _user, _passwd, _perm)).
derived(disableFirewall(_host)).



meta(dif(_,_)).
meta(attackGoal(_)).
meta(hasAccount(_,_,_,_)).



