interaction_rule(
  (execCode(HostD, Perm) :-
	execCode(HostS, _),
	weakAccount(HostD, _, _, Perm),
	hacl(HostS, HostD, Protocol, Port),
	dif(Port, 2049),
	dif(Port, 873)),
  rule_desc('Brute Force Password Spraying - T1110.003', 1.0)
).


/****** Execution ******/
interaction_rule(
  (execCode(H, Perm) :-
	ttpExists(H, _, Software, _, clientVulnerability, execution),
	networkServiceInfo(H, Software, Protocol, Port, Perm),
	attackVectorInjection(H, _, Protocol, Port)),
  rule_desc('Exploitation for Client Execution internet - T1203', 1.0)
).


/****** Impact ******/
