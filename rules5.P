/******************************************************/
/****         Interaction Rules                   *****/
/******************************************************/

% 自定义 dif 谓词
dif(X, Y) :-
    X \= Y.

/****** initial access ******/
interaction_rule(
  (attackVectorInjection(H, Perm, Protocol, Port) :-
	attackerLocated(Zone),
 	inCompetent(User, H, Perm),
	hacl(Zone, H, Protocol, Port)),
  rule_desc('Insecure Operations Leading to Attack Vector Injection',
  1.0)).


interaction_rule(
  (netAccess(H, Protocol, Port) :-
	attackerLocated(Zone),
	hacl(Zone, H, Protocol, Port)),
  rule_desc('Direct Network Access',
  1.0)).

interaction_rule(
  (execCode(H, Perm) :-
	attackerLocated(Zone),
	hacl(Zone, H, _, _),
	leakAccount(_, H, Perm)),
  rule_desc('Valid Accounts - T1078', 1.0)
).

interaction_rule(
  (execCode(H, Perm) :-
	attackerLocated(Zone),
	hacl(Zone, H, _, _),
	weakAccount(H, User, Passwd, Perm)),
  rule_desc('Brute Force Password Spraying - T1110.003', 1.0)
).

interaction_rule(
  (execCode(H, Perm) :-
	ttpExists(H, _, Software, remoteExploit, publicApplicationExploit, initialAccess),
	networkServiceInfo(H, Software, Protocol, Port, Perm),
	netAccess(H, Protocol, Port)),
  rule_desc('Exploit Public-Facing Application - T1190', 1.0)
).

/****** Credential Access ******/
interaction_rule(
  (getAccount(H, User, Passwd, Perm) :-
	ttpExists(H, Software, _, lsassCredentialDumping, credentialAccess),
	networkServiceInfo(H, Software, _, _, _),
	hasAccount(H, User, Passwd, Perm),
	execCode(H, admin)),
  rule_desc('OS Credential Dumping LSASS Memory - T1003.001', 1.0)
).

interaction_rule(
  (getAccount(H, User, Passwd, Perm) :-
	ttpExists(H, Software, _, domainCredentialDumping, credentialAccess),
	networkServiceInfo(H, Software, _, _, system),
	hasAccount(H, User, Passwd, Perm),
	execCode(H, system)),
  rule_desc('OS Credential Dumping LSASS Memory - T1003.001', 1.0)
).

